{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Kellnr Helm chart values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "pullPolicy": { "type": "string" },
        "tag": { "type": "string" }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "configMap": {
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      }
    },
    "secret": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "existingSecret": { "type": "string" }
      }
    },
    "extraEnvVars": { "type": "array" },
    "extraEnvVarsCM": { "type": "string" },
    "extraEnvVarsSecret": { "type": "string" },
    "startupProbe": { "$ref": "#/definitions/probe" },
    "livenessProbe": { "$ref": "#/definitions/probe" },
    "readinessProbe": { "$ref": "#/definitions/probe" },
    "kellnr": {
      "type": "object",
      "required": ["origin"],
      "properties": {
        "origin": {
          "type": "object",
          "required": ["hostname"],
          "properties": {
            "hostname": { "type": "string", "minLength": 1 },
            "port": { "type": ["integer", "null"] },
            "protocol": { "type": ["string", "null"] }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "api": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        }
      }
    },
    "ingress": { "$ref": "#/definitions/toggle" },
    "httproute": { "$ref": "#/definitions/toggle" },
    "certificate": { "$ref": "#/definitions/toggle" },
    "importCert": { "$ref": "#/definitions/toggle" },
    "docBuilder": { "$ref": "#/definitions/toggle" },
    "dns": { "$ref": "#/definitions/toggle" },
    "pv": { "$ref": "#/definitions/toggle" },
    "pvc": { "$ref": "#/definitions/toggle" },
    "pdb": { "$ref": "#/definitions/toggle" },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "definitions": {
    "toggle": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "probe": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string" },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 },
        "successThreshold": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
